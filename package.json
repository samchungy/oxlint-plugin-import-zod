{
  "name": "oxlint-plugin-import-zod",
  "version": "1.0.0",
  "description": "Oxlint plugin to enforce namespace imports for zod",
  "keywords": [
    "imports",
    "oxlint",
    "oxlint-plugin",
    "oxlintplugin",
    "zod"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/samchungy/oxlint-plugin-import-zod.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint src tests",
    "build": "tsdown",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@oxlint/plugins": "^1.74.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@types/node": "^20.5.7",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tsdown": "0.22.8",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.34.4"
}
